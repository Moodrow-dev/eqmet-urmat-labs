<Group view="code" hide-input="false" labelreference="L85" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8"># 8 - \320\277\321\203\321\201\321\202\321\214 x&lt;0 \320\263\320\270\320\277\320\265\321\200\320\261\320\276\320\273\320\270\321\207\320\265\321\201\320\272\320\270\320\271 \321\202\320\270\320\277
</Font>a := 1, 0, x, 0, 0, 0, 0;
eq := a[1]*diff(u(x, y), x, x) + a[2]*diff(u(x, y), x, y)+ a[3]*diff(u(x, y),y ,y) + a[4]*diff(u(x, y), x)+ a[5]*diff(u(x, y), y) + a[6]*u(x, y) + a[7]=0;
A := linalg[matrix](2, 2, [a[1], a[2]/2, a[2]/2, a[3]]);
Delta := simplify(linalg[det](A));
eqh := a[1]*z^2 - a[2]*z + a[3] = 0;
res1 := {solve(eqh,z)};
res1 := subs(y=y(x),res1);
res2 := {seq(dsolve(diff(y(x), x) = res1[i], y(x)),i=1..nops(res1))};
res2 := subs(y(x) = y, res2);
itr := {xi=solve(res2[1],_C1),eta=solve(res2[2],_C1)};
tr := solve(itr, {x,y});
convert(tr,radical);
PDEtools[dchange](tr,eq,itr,[xi,eta],simplify);</Text-field>
</Input>
