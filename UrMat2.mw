<Group hide-input="false" labelreference="L95" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart;
eq := diff(u(x, y), x, x)- 2*diff(u(x, y), x, y)- 3*diff(u(x, y), y, y) = 0;
with(PDEtools):
mapde(eq, canom);
op(%);
pdsolve(%[1]);
u(x,y) = subs(%%[2], rhs(%));
simplify(subs(%, eq));
simplify(%);</Text-field>
</Input>
